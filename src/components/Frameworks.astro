---
import { frameworks } from "../data/frameworks.json";
import { Icon } from "astro-icon/components";

interface Framework {
    name: string;
    icon: string;
}

const frameworkList: Framework[] = frameworks;
---

<div class="frameworks">
    <h1>Frameworks</h1>
    <!--Put these as the images/icons of the frameworks, or name + icon next to them -->
    <div class="framework-list">
        {
            frameworkList.map((framework) => (
                <div class="framework-item">
                    <Icon name={framework.icon} />
                    <span>{framework.name}</span>
                </div>
            ))
        }
    </div>

    <style>
        span {
            margin: 0;
            vertical-align: sub;
        }

        .framework-item {
            margin: 0.5em 1em;
            display: inline-block;
            width: fit-content;
            padding: 0.6em;
            border-radius: 0.5em;
            border: 1px solid #bab4bb;
        }

        [data-icon] {
            vertical-align: text-top;
            margin-top: -0.1em;
            height: 25px;
            width: 25px;
            padding-right: 5px;
        }
        h1 {
            font-size: 25px;
            margin-bottom: 0.5em;
        }
    </style>
</div>
