---
import { languages } from "../data/languages.json";
import { Icon } from "astro-icon/components";

interface Language {
    name: string;
    icon: string;
}

const languageList: Language[] = languages;
---

<div class="languages">
    <h1>Languages</h1>
    <!--Put these as the images/icons of the languages, or name + icon next to them -->
    <div class="language-list">
        {
            languageList.map((language) => (
                <div class="language-item">
                    <Icon name={language.icon} />
                    <span>{language.name}</span>
                </div>
            ))
        }
    </div>

    <style>
        span {
            margin: 0;
            vertical-align: sub;
        }

        .language-item {
            margin: 0.5em 1em;
            display: inline-block;
            width: fit-content;
            padding: 0.6em;
            border-radius: 0.5em;
            border: 1px solid #bab4bb;
        }

        [data-icon] {
            vertical-align: text-top;
            margin-top: -0.1em;
            height: 25px;
            width: 25px;
            padding-right: 5px;
        }
        h1 {
            font-size: 25px;
            margin-bottom: 0.5em;
        }
    </style>
</div>
